# IMAP Server
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=your.email@example.com
IMAP_PASSWORD=your_app_password
IMAP_USE_SSL=true
# IMAP_TLS_CA_BUNDLE=/path/to/ca-bundle.pem  # Custom CA bundle for IMAP TLS verification
# IMAP_TIMEOUT=30  # Socket timeout (seconds) for IMAP operations. Must be > 0.
# IMAP_ALLOWED_FOLDERS=INBOX,Sent,Archive  # Defaults to INBOX if not set. Empty value = unrestricted.

# SMTP Server (optional, falls back to IMAP credentials if not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your.email@example.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=true
# SMTP_TLS_CA_BUNDLE=/path/to/ca-bundle.pem  # Custom CA bundle for SMTP TLS (falls back to IMAP_TLS_CA_BUNDLE)

# MCP Transport (Docker defaults)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8010

# OIDC Authentication (required for streamable-http)
# OIDC_ISSUER_URL and OIDC_AUDIENCE are both REQUIRED for HTTP transport.
# OIDC_AUDIENCE binds tokens to this server (the 'aud' claim) — without it,
# tokens minted for other resource servers of the same issuer could be replayed.
# OIDC_ISSUER_URL=https://auth.example.com/application/o/your-app/
# OIDC_AUDIENCE=your-mcp-server-audience
# OIDC_JWKS_URI=
# MCP_RESOURCE_SERVER_URL=https://mcp.example.com/mcp
# Opt out of the audience requirement (disables 'aud' verification — NOT recommended):
# OIDC_ALLOW_ANY_AUDIENCE=true

# HTTP transport
# Tool results are returned as a single JSON HTTP response by default (not an
# SSE stream). This avoids a Codex streamable-HTTP client bug where a stale MCP
# session wedges every later tool call until its ~300s deadline. Set to 'false'
# to restore SSE-stream responses:
# IMAP_MCP_HTTP_JSON_RESPONSE=false

# Security
# IMAP_MCP_LOAD_DOTENV=true  # Set to 'true' to load .env file (disabled by default for security)
# IMAP_MCP_SKIP_CONFIRMATION=true  # Skip destructive action confirmation (CI/automation only)

# Observability
# IMAP_MCP_LOG_FORMAT=json  # Log format: 'text' (default, human-readable) or 'json' (for log aggregators)
# A Prometheus /metrics endpoint and per-request X-Request-ID correlation IDs
# are enabled automatically on the streamable-http transport.

# Traefik domain
IMAP_MCP_DOMAIN=mcp.example.com
